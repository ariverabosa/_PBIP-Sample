	measure 'KPI Indigenous Change No to Yes (AY and Session)' =
			
			VAR WindowStart =
			    CALCULATE ( MIN ( DimTerm[TermStartDate] ) )
			VAR WindowEnd =
			    CALCULATE ( MAX ( DimTerm[TermEndDate] ) )
			
			VAR PeopleInScope =
			    VALUES ( FactPrograms[person_pk] )
			
			VAR ChangeEvents_NoToYes_InWindow =
			    FILTER (
			        ADDCOLUMNS (
			            ALL ( 'Type2 changes' ),
			            "PrevInd",
			                VAR pk = 'Type2 changes'[person_pk]
			                VAR vf = 'Type2 changes'[ValidFrom]
			                RETURN
			                    MAXX (
			                        TOPN (
			                            1,
			                            FILTER (
			                                ALL ( 'Type2 changes' ),
			                                'Type2 changes'[person_pk] = pk
			                                    && 'Type2 changes'[ValidFrom] < vf
			                            ),
			                            'Type2 changes'[ValidFrom], DESC
			                        ),
			                        'Type2 changes'[isIndigenous]
			                    )
			        ),
			        'Type2 changes'[ValidFrom] >= WindowStart
			            && 'Type2 changes'[ValidFrom] <= WindowEnd
			            && [PrevInd] = "No"
			            && 'Type2 changes'[isIndigenous] = "Yes"
			    )
			
			VAR PeopleWhoChanged =
			    SELECTCOLUMNS ( ChangeEvents_NoToYes_InWindow, "person_pk", 'Type2 changes'[person_pk] )
			
			RETURN
			COUNTROWS ( INTERSECT ( PeopleInScope, PeopleWhoChanged ) )
		formatString: 0
		displayFolder: Indigenous
		lineageTag: a06db269-913a-41df-a32c-71ad9b441fca

