	measure 'Top N Citiz' = ```
			
			VAR _TopNSelected = SELECTEDVALUE('TopN Selection'[Value])
			VAR _TopCitizTable =
			    TOPN(
			            _TopNSelected,
			            ALLSELECTED('Pseudo Citizen table'),
			            [Distinct Students, International Visa]
			         )
			VAR _TopCitizCount = 
			    CALCULATE(
			        [Distinct Students, International Visa],
			        KEEPFILTERS(_TopCitizTable)
			        )
			VAR _OthersCount = 
			    CALCULATE(
			        [Distinct Students, International Visa],
			        ALLSELECTED('Pseudo Citizen table')
			    ) - 
			    CALCULATE(
			        [Distinct Students, International Visa],
			        _TopCitizTable
			    )
			VAR _currentCitiz = SELECTEDVALUE('Pseudo Citizen table'[CitizenshipName])
			
			RETURN
			IF(
			    _currentCitiz <> "Others",
			    _TopCitizCount,
			    _OthersCount
			)
			```
		formatString: #,0
		displayFolder: International Total
		lineageTag: 08a8397e-7c09-4fd8-bba4-ef1a1c0ffc01

	measure 'TopN Rank' =
			
