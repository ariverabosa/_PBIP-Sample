	measure 'Percentage Female' = ```
			
			VAR _selectedAY = SELECTEDVALUE(DimTerm[Academic Year Name])
			VAR _defaultAY = LOOKUPVALUE(DimTerm[Academic Year Name], DimTerm[YearLabel], "LatestYear")
			VAR _Total =
			    CALCULATE(
			        [Distinct Students DaysBetween],
			        FILTER(DimTerm, DimTerm[Academic Year Name] = _selectedAY))
			VAR _Female = 
			    CALCULATE(
			        [Distinct Students DaysBetween],
			        FILTER(DimStudent,DimStudent[New_Gender] = "Female"),
			        FILTER(DimTerm, DimTerm[Academic Year Name] = _selectedAY)
			    )
			VAR _pct = DIVIDE(_Female, _Total, 0)
			VAR _absPct = ABS(_pct)
			
			
			VAR _pctText =
			    IF(
			        _absPct > 0 && _absPct < 0.01,
			        "<1%",
			        FORMAT(_absPct, "#0%")
			    )    
			RETURN
			_pct
			```
		formatString: 0%;-0%;0%
		displayFolder: Female
		lineageTag: 6f5f9987-9a40-42e8-bd43-12b438f4912c

