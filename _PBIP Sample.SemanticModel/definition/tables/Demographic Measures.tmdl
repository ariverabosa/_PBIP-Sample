	measure 'Intl 5 Yr % (Percent of Parent)' = ```
			
			VAR _Num = [Distinct Students, International]
			
			VAR _IsProgram =
			    ISINSCOPE(DimProgramTrack[ProgramTitle])   -- replace if needed
			VAR _IsFamily =
			    ISINSCOPE(DimProgramTrack[FamilyAcademicProgramTitle])  -- replace if needed
			VAR _IsDivision =
			    ISINSCOPE(DimOrganizationalUnit[AnalyticDivisionName])
			
			VAR _IsGrandTotal =
			    NOT ( _IsProgram || _IsFamily || _IsDivision )
			
			VAR _Den =
			    SWITCH(
			        TRUE(),
			
			        /* Program row: Program / Family */
			        _IsProgram,
			            CALCULATE(
			                [Distinct Students, International],
			                REMOVEFILTERS(DimProgramTrack[ProgramTitle])
			            ),
			
			        /* Family row: Family / Division */
			        _IsFamily,
			            CALCULATE(
			                [Distinct Students, International],
			                REMOVEFILTERS(DimProgramTrack[ProgramTitle]),
			                REMOVEFILTERS(DimProgramTrack[FamilyAcademicProgramTitle])
			            ),
			
			        /* Division row: Division / All Divisions */
			        _IsDivision,
			            CALCULATE(
			                [Distinct Students, International],
			                REMOVEFILTERS(DimProgramTrack[ProgramTitle]),
			                REMOVEFILTERS(DimProgramTrack[FamilyAcademicProgramTitle]),
			                REMOVEFILTERS(DimOrganizationalUnit[AnalyticDivisionName])
			            ),
			
			        BLANK()
			    )
			
			RETURN
			IF(
			    _IsGrandTotal,
			    BLANK(),
			    DIVIDE(_Num, _Den)
			)
			
			```
		formatString: 0%;-0%;0%
		displayFolder: International Total
		lineageTag: 3d15abb6-a1d3-4b77-b2ae-71795e99c37b

