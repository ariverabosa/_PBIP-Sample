		formatString: #,0
		displayFolder: International Non-visa
		lineageTag: 64c6d6c9-cec9-472d-b067-fddef70b4151

	measure 'Distinct Students, International Visa, LY' =
			
			VAR _CY_AYName =
			    SELECTEDVALUE ( DimTerm[Academic Year Name] )
			VAR _LY_AYName =
			    LOOKUPVALUE (
			        DimTerm[LY_AcademicName],
			        DimTerm[Academic Year Name], _CY_AYName
			    )
			RETURN
			CALCULATE (
			    [Distinct Students, International Visa],
			    REMOVEFILTERS ( DimTerm[Academic Year Name] ),
			    TREATAS ( { _LY_AYName }, DimTerm[Academic Year Name] ))
		formatString: #,0
		displayFolder: International Visa
		lineageTag: d1db2db3-541d-4f6b-a95b-42a085b1aeef

	measure 'Percentage International Visa' =
			
			DIVIDE([Distinct Students, International Visa], [Distinct Students DaysBetween], BLANK())
		formatString: 0%;-0%;0%
		displayFolder: International Visa
		lineageTag: fd5010d9-a16c-4178-920c-c23a50c2a957

	measure 'Percentage International Non-Visa' =
			
			DIVIDE([Distinct Students, International Non-visa], [Distinct Students DaysBetween], BLANK())
		formatString: 0%;-0%;0%
		displayFolder: International Non-visa
		lineageTag: bd8381ff-1739-4043-8b32-777634a4706e

	measure 'Ref Label Domestic (Non-Indigenous)' = ```
			
			VAR _dom = [Distinct Students, Domestic (Non-Indigenous)]
			RETURN
			FORMAT(_dom, "0,#") & " students" 
			```
		displayFolder: Domestic (Non-Indigenous)
		lineageTag: 9bdbea99-52d5-455a-b0a3-5acb139cae10

	measure 'Distinct Students, International Non-visa, LY' =
			
			VAR _CY_AYName =
			    SELECTEDVALUE ( DimTerm[Academic Year Name] )
			VAR _LY_AYName =
			    LOOKUPVALUE (
			        DimTerm[LY_AcademicName],
			        DimTerm[Academic Year Name], _CY_AYName
			    )
			RETURN
			CALCULATE (
			    [Distinct Students, International Non-visa],
			    REMOVEFILTERS ( DimTerm[Academic Year Name] ),
			    TREATAS ( { _LY_AYName }, DimTerm[Academic Year Name] ))
		formatString: 0
		displayFolder: International Non-visa
		lineageTag: 1fcb7c15-767e-44b9-adf7-573d386c049e

	measure 'Indigenous Var %' =
			
			VAR _diff = [Distinct Students, Indigenous] - [Distinct Students, Indigenous, LY]  // Keep this as is
			VAR _varYoY = DIVIDE ( _diff, [Distinct Students, Indigenous, LY] ) // Keep this as is
			RETURN
			_varYoY
		formatString: 0%;-0%;0%
		displayFolder: Indigenous
		lineageTag: 04c3ff51-6750-42f1-a32b-a55e3cbe2b4e

	measure 'TopN Color' =
			
			SWITCH(
			    SELECTEDVALUE('Pseudo Citizen table'[CitizenshipName]),
			    "Others", "#D9D9D9",
			    "#3550D4"
			)
		displayFolder: International Total
		lineageTag: 53f88666-3db7-4eec-bfa9-72e4d3af1a24

	measure 'TopN Title' = ```
			
			VAR _top = SELECTEDVALUE('TopN Selection'[Value])
			RETURN
			IF(ISBLANK(_top),
			"INTERNATIONAL STUDENTS BY COUNTRY",
			"INTERNATIONAL STUDENTS BY COUNTRY | Top"  
			)
			```
		displayFolder: International Total
		lineageTag: 0a6683e1-34ff-401f-9b0a-fc9a1312d23a

	measure 'Distinct Students, Non-Indigenous' = ```
			
			CALCULATE([Distinct Students, Domestic], 
			    FILTER(DimStudent, DimStudent[isIndigenous] = "No"))
			```
		formatString: 0
		displayFolder: Domestic (Non-Indigenous)
		lineageTag: f49efe3b-2862-4b46-941d-e05be5171a3a

	measure 'Distinct Students,Domestic (Non-Indigenous), Female' = ```
			
			    CALCULATE(
			       [Distinct Students, Domestic (Non-Indigenous)],
			        FILTER(DimStudent,DimStudent[New_Gender] = "Female"))
			```
		formatString: 0
		lineageTag: 9840cd3d-2e3b-4b1b-bbd3-0fdd6d754f67

	partition 'Demographic Measures' = m
		mode: import
		source =
				let
				    Source = Table.FromRows(Json.Document(Binary.Decompress(Binary.FromText("i44FAA==", BinaryEncoding.Base64), Compression.Deflate)), let _t = ((type nullable text) meta [Serialized.Text = true]) in type table [Column1 = _t]),
				    #"Changed Type" = Table.TransformColumnTypes(Source,{{"Column1", type text}}),
				    #"Removed Columns" = Table.RemoveColumns(#"Changed Type",{"Column1"})
				in
				    #"Removed Columns"

	annotation PBI_ResultType = Table

