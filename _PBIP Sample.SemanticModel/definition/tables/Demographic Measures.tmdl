	measure 'Distinct Students, Domestic, LY' =
			
			VAR _CY_AYName =
			    SELECTEDVALUE ( DimTerm[Academic Year Name] )
			VAR _LY_AYName =
			    LOOKUPVALUE (
			        DimTerm[LY_AcademicName],
			        DimTerm[Academic Year Name], _CY_AYName
			    )
			RETURN
			CALCULATE (
			    [Distinct Students, Domestic],
			    REMOVEFILTERS ( DimTerm[Academic Year Name] ),
			    TREATAS ( { _LY_AYName }, DimTerm[Academic Year Name] ))
