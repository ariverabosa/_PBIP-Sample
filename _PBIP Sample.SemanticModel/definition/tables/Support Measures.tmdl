	measure 'Total Student Selector' =
			
			
			VAR _activity =
			    SELECTEDVALUE( 'Student Type Selector'[Student Type] )
			
			VAR _value =
			    SWITCH(
			        TRUE(),
			        _activity = "Domestic Non-indigenous", [Distinct Students, Domestic (Non-Indigenous)],
			        _activity = "Domestic Indigenous", [Distinct Students, Indigenous],
			        _activity = "International Visa", [Distinct Students, International Visa],
			        _activity = "International Non-visa", [Distinct Students, International Non-visa],
			        BLANK()
			    )
			
			RETURN
			_value
		formatString: #,0
		lineageTag: 455ac615-16cf-47f1-b777-f54affa87957

	measure 'YoY Student Selector' =
			
			
			VAR _activity =
			    SELECTEDVALUE( 'Student Type Selector'[Student Type] )
			
			VAR _value =
			    SWITCH(
			        TRUE(),
			        _activity = "Domestic Non-indigenous", [Percent Change Distinct Count Domestic Non-Indigenous],
			        _activity = "Domestic Indigenous", [Percent Change Distinct Count Indigenous],
			        _activity = "International Visa", [Percent Change Distinct Count International Visa],
			        _activity = "International Non-visa", [Percent Change Distinct Count International Non-visa],
			        BLANK()
			    )
			
			RETURN
			_value
		formatString: 0%;-0%;0%
		lineageTag: f3b668c0-3b14-44d3-b6a9-ec1592a8d54e

