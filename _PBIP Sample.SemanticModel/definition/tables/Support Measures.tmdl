	measure 'Overview Title' = ```
			
			VAR _Diff = [Distinct Students DaysBetween] - [Distinct Students DaysBetween, LY]  // Keep this as is
			VAR _pct = DIVIDE ( _Diff, [Distinct Students DaysBetween, LY] ) // Keep this as is
			VAR _year = SELECTEDVALUE(DimTerm[Academic Year Name])
			VAR _text = "Credential program " 
			
			--General Pattern
			VAR _roundedPct =
			    ROUND ( ABS ( _pct ), 3 ) 
			    -- 3 decimals here means 0.001 = 0.1 percentage points
			
			VAR _direction =
			    SWITCH (
			        TRUE(),
			        _pct > 0, "increased",
			        _pct < 0, "declined",
			        "Remained stable"
			    )
			
			RETURN
			SWITCH (
			    TRUE(),
			
			    ISBLANK ( _pct ),
			        _text & "headcount in " & _year,
			
			    _roundedPct = 0,
			        _text & "headcount remained stable in " & _year,
			
			    _roundedPct >= 0.01,
			        _text & "headcount "
			            & _direction
			            & " "
			            & FORMAT ( _roundedPct, "0%" )
			            & " in "
			            & _year,
			
			    _text & "headcount changed slightly in " & _year
			)
			```
		displayFolder: Dynamic Titles
		lineageTag: ed1ed3d9-2443-4c7d-b1af-393bb758f523

	measure 'Overview subtitle' = ```
			
			
			VAR _Diff = [Distinct Students DaysBetween] - [Distinct Students DaysBetween, LY]  // Keep this as is
			VAR _pct = DIVIDE ( _Diff, [Distinct Students DaysBetween, LY] ) // Keep this as is
			VAR _ValueLY = [Distinct Students DaysBetween, LY]
			
			VAR _year = SELECTEDVALUE(DimTerm[Academic Year Name])
			
			VAR _absPct = ABS(_pct)
			VAR _absValue = ABS(_Diff)
			
			VAR _sign =
			        IF (
			            _pct > 0,
			            "increase ",
			            "decline "
			        )   // Correct the sign logic
			 
			RETURN
			"Which academic schools are driving the " & _sign & " in " & _year & "?"
			 
			```
		displayFolder: Dynamic Titles
		lineageTag: 80374a3e-ced1-4fa0-945f-d67e76220fdf

