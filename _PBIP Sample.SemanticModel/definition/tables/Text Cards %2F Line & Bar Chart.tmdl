	measure 'Value for Bar Chart' = ```
			
			VAR _current = [Selected Trend Metric]
			VAR _ly = [Selected Trend Metric LY]
			VAR _Diff = _current - _ly
			VAR _pct = DIVIDE ( _Diff, _ly )
			VAR _absValue = ABS ( _Diff )
			VAR _absPct = ABS ( _pct )
			VAR _label = [Selected Trend Metric Label]
			
			VAR _operatorNumber =
			    SWITCH (
			        TRUE(),
			        _Diff > 0, UNICHAR(43) & " " & FORMAT ( _absValue, "#,##0" ),
			        _Diff < 0, UNICHAR(45) & " " & FORMAT ( _absValue, "#,##0" ),
			        FORMAT ( _absValue, "#,##0" )
			    )
			
			VAR _arrowNumber =
			    SWITCH (
			        TRUE(),
			        _pct > 0, UNICHAR(129121) & " " & FORMAT ( _pct, "0%" ),
			        _pct < 0, UNICHAR(129123) & " " & FORMAT ( _absPct, "0%" ),
			        FORMAT ( _absPct, "0%" )
			    )
			
			RETURN
			     //_label
			       // & ": " &
			        FORMAT ( _current, "#,##0" )
			        & " | "
			        & _operatorNumber
			        & " | "
			        & _arrowNumber
			
			
			```
