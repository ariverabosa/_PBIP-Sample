	measure 'Card 5-2 Text Number and %' = ```
			
			VAR _Diff = [Distinct Students, International Non-visa] - [Distinct Students, International Non-visa, LY]  // Keep this as is
			VAR _pct = DIVIDE ( _Diff, [Distinct Students, International Non-visa, LY] ) // Keep this as is
			VAR _ValueLY = [Distinct Students, International Non-visa, LY]
			
			VAR _absPct = ABS(_pct)
			VAR _absValue = ABS(_Diff)
			
			// Math operator and number +105
			VAR _operatorNumber = 
			    SWITCH(
			        TRUE(),
			        _Diff  > 0, UNICHAR(43) & " " & FORMAT(_absValue, "0"),
			        _Diff  < 0, UNICHAR(45) & " " & FORMAT(_absValue, "0"),
			        FORMAT(_absValue, "0")
			    )
			
			// Arrow and % change
			VAR _arrowNumber = 
			    SWITCH(
			        TRUE(),
			        _pct > 1, UNICHAR(129109) & " " & FORMAT(_pct, "0%"),
			        _pct < 0, UNICHAR(129110) & " " & FORMAT(_absPct, "0%"),
			        FORMAT(_pct, "0%")
			    )
			
			RETURN
			// _operatorNumber & " | " & _arrowNumber
			//_arrowNumber & " | " & _operatorNumber
			_arrowNumber
			```
		displayFolder: International Non-visa
		lineageTag: fcc0d16c-88d6-41f1-95b3-10f32f7d226d

	measure 'Card 5-3 Text comparison' = ```
			
			VAR _maxDate = MAX(DimDate[Date])
			VAR _year = YEAR(_maxDate)
			VAR _month = MONTH(_maxDate)
			VAR _CY_StartYear = IF(_month <= 6, _year - 2, _year)
			VAR _CY_EndYear = _CY_StartYear + 1
			VAR _CYNName = FORMAT(_CY_StartYear, "0000")  & "-" & FORMAT(MOD(_CY_EndYear, 100), "00")
			
			VAR _Session = SELECTEDVALUE(DimTerm[Session], "")
			VAR _YearName = SELECTEDVALUE(DimTerm[Academic Year Name], "")
			VAR _LY = LOOKUPVALUE(DimTerm[LY_AcademicName], DimTerm[Academic Year Name], _YearName)
			VAR _HasSession = _Session <> ""
			VAR _HasYear = TRIM(_YearName) <> ""
			
			//  % Change
			VAR _value = [Distinct Students, International Non-visa] - [Distinct Students, International Non-visa, LY]  // Keep this as is
			VAR _pct = DIVIDE ( _value, [Distinct Students, International Non-visa, LY] ) // Keep this as is
			VAR _valueLY = [Distinct Students, International Non-visa, LY]
			
			VAR _absPct = ABS(_pct)
			VAR _absValue = ABS(_value)
			
			VAR _symbol = 
			    SWITCH(
			        TRUE(),
			        _pct > 0, UNICHAR(11165) & " " & FORMAT(_pct, "0%"),
			        _pct < 0, UNICHAR(11167) & " " & FORMAT(_absPct, "0%"),
			        FORMAT(_pct, "0%")
			    )
			
			RETURN
			"vs to LY, " & 
			SWITCH(
			        TRUE(),
			        _HasSession && _HasYear,        _LY, // & " " & _Session,
			        _HasSession && NOT _HasYear,    _CYNName, // & " " & _Session,
			        NOT _HasSession && _HasYear,    _LY,
			        _CYNName                        // default
			    )
			```
		displayFolder: International Non-visa
		lineageTag: 81b8cb5e-eada-4805-aebf-dccabc2b6eb3

	measure 'Card 5-4 Reference label color value' = ```
			
			VAR _value = [Distinct Students, International Non-visa] - [Distinct Students, International Non-visa, LY]  // Keep this as is
			VAR _pct = DIVIDE ( _value, [Distinct Students, International Non-visa, LY] ) // Keep this as is
			VAR _valueLY = [Distinct Students, International Non-visa, LY]
			
			VAR _absPct = ABS(_pct)
			VAR _absValue = ABS(_value)
			
			VAR _pctRounded =
			    ROUND ( _pct, 2 )
			
			VAR _format = 
			    SWITCH(
			        TRUE(),
			        ISBLANK(_pct), "Grey",
			        _pctRounded <= -0.01, "Red",
			        _pctRounded >= 0.01, "Green",
			        "Grey"
			    )
			RETURN
			_format 
			```
		displayFolder: International Non-visa
		lineageTag: d1555ee0-4eeb-4fa3-8306-a957eea15ef2

