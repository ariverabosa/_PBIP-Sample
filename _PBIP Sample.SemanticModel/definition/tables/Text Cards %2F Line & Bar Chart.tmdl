table 'Text Cards / Line & Bar Chart'
	lineageTag: 3174754e-397a-45dc-8aa4-cdfb39902abb

	measure 'Card 1-2 Text Number and %' = ```
			
			VAR _Diff = [Distinct Students DaysBetween] - [Distinct Students DaysBetween, LY]  // Keep this as is
			VAR _pct = DIVIDE ( _Diff, [Distinct Students DaysBetween, LY] ) // Keep this as is
			VAR _ValueLY = [Distinct Students DaysBetween, LY]
			
			VAR _absPct = ABS(_pct)
			VAR _absValue = ABS(_Diff)
			
			// Math operator and number +105
			VAR _operatorNumber = 
			    SWITCH(
			        TRUE(),
			        _Diff  > 0, UNICHAR(43) & " " & FORMAT(_absValue, "0"),
			        _Diff  < 0, UNICHAR(45) & " " & FORMAT(_absValue, "0"),
			        FORMAT(_absValue, "0")
			    )
			
			// Arrow and % change
			VAR _arrowNumber = 
			    SWITCH(
			        TRUE(),
			        // _pct > 0, UNICHAR(11165) & " " & FORMAT(_pct, "0%"),
			        // _pct < 0, UNICHAR(11167) & " " & FORMAT(_absPct, "0%"),
			        _pct > 0, UNICHAR(129109) & " " & FORMAT(_pct, "0%"),
			        _pct < 0, UNICHAR(129110) & " " & FORMAT(_absPct, "0%"),
			        FORMAT(_pct, "0%")
			        
			)
			
			
			
			RETURN
			//_arrowNumber & " | " & _operatorNumber
			_arrowNumber 
			// _operatorNumber
			
			```
		displayFolder: Annual
		lineageTag: 7cb4aba0-b796-4e47-a4a2-050b4f542b5a

	measure 'Card 1-3 Text comparison' = ```
			
			VAR _maxDate = MAX(DimDate[Date])
			VAR _year = YEAR(_maxDate)
			VAR _month = MONTH(_maxDate)
			VAR _CY_StartYear = IF(_month <= 6, _year - 2, _year)
			VAR _CY_EndYear = _CY_StartYear + 1
			VAR _CYNName = FORMAT(_CY_StartYear, "0000")  & "-" & FORMAT(MOD(_CY_EndYear, 100), "00")
			
			VAR _Session = SELECTEDVALUE(DimTerm[Session], "")
			VAR _YearName = SELECTEDVALUE(DimTerm[Academic Year Name], "")
			VAR _LY = LOOKUPVALUE(DimTerm[LY_AcademicName], DimTerm[Academic Year Name], _YearName)
			VAR _HasSession = _Session <> ""
			VAR _HasYear = TRIM(_YearName) <> ""
			
			//  % Change
			VAR _value = [Distinct Students DaysBetween] - [Distinct Students DaysBetween, LY]  // Keep this as is
			VAR _pct = DIVIDE ( _value, [Distinct Students DaysBetween, LY] ) // Keep this as is
			VAR _valueLY = [Distinct Students DaysBetween, LY]
			
			VAR _absPct = ABS(_pct)
			VAR _absValue = ABS(_value)
			
			VAR _symbol = 
			    SWITCH(
			        TRUE(),
			        _pct > 0, UNICHAR(11165) & " " & FORMAT(_pct, "0%"),
			        _pct < 0, UNICHAR(11167) & " " & FORMAT(_absPct, "0%"),
			        FORMAT(_pct, "0%")
			    )
			
			RETURN
			"vs AY, " & 
			SWITCH(
			        TRUE(),
			        _HasSession && _HasYear,        _LY,     //& " " & _Session,
			        _HasSession && NOT _HasYear,    _CYNName, //& " " & _Session,
			        NOT _HasSession && _HasYear,    _LY,
			        _CYNName                        // default
			    )
			```
		displayFolder: Annual
		lineageTag: 56a24b43-7c6e-4370-ad17-7df980463b57

	measure 'Card 1-1 Text SubTitle' = ```
			
			
			VAR _maxDate = MAX(DimDate[Date])
			VAR _year = YEAR(_maxDate)-1
			VAR _month = MONTH(_maxDate)
			VAR _CY_StartYear = IF(_month <= 6, _year - 1, _year)
			VAR _CY_EndYear = _CY_StartYear + 1
			VAR _CYNName = FORMAT(_CY_StartYear, "0000")  & "-" & FORMAT(MOD(_CY_EndYear, 100), "00")
			
			VAR _Session = SELECTEDVALUE(DimTerm[Session], "")
			VAR _YearName = SELECTEDVALUE(DimTerm[Academic Year Name], "")
			VAR _HasSession = _Session <> ""
			VAR _HasYear = TRIM(_YearName) <> ""
			
			RETURN
			"Total Students, AY " & 
			SWITCH(
			        TRUE(),
			        _HasSession && _HasYear,        _YearName & " " & _Session,
			        _HasSession && NOT _HasYear,    _CYNName & " " & _Session,
			        NOT _HasSession && _HasYear,    _YearName,
			        _CYNName                        // default
			    )
			
			
			```
		displayFolder: Annual
		lineageTag: 08244847-3bea-4ebf-be7c-77b929aed754

	measure 'Card 2-2 Text Number and %' = ```
			
			VAR _Diff = [Distinct Students, Domestic (Non-Indigenous)] - [Distinct Students, Domestic (Non-Indigenous), LY]  // Keep this as is
			VAR _pct = DIVIDE ( _Diff, [Distinct Students, Domestic (Non-Indigenous), LY] ) // Keep this as is
			VAR _ValueLY = [Distinct Students, Domestic (Non-Indigenous), LY]
			
			VAR _absPct = ABS(_pct)
			VAR _absValue = ABS(_Diff)
			
			// Math operator and number +105
			VAR _operatorNumber = 
			    SWITCH(
			        TRUE(),
			        _Diff  > 0, UNICHAR(43) & " " & FORMAT(_absValue, "0"),
			        _Diff  < 0, UNICHAR(45) & " " & FORMAT(_absValue, "0"),
			        FORMAT(_absValue, "0")
			    )
			
			// Arrow and % change
			VAR _arrowNumber = 
			    SWITCH(
			        TRUE(),
			        _pct > 0, UNICHAR(129109) & " " & FORMAT(_pct, "0%"),
			        _pct < -0.01, UNICHAR(129110) & " " & FORMAT(_absPct, "0%"),
			        FORMAT(_pct, "0%")
			    )
			
			RETURN
			//_operatorNumber & " | " & _arrowNumber
			//_arrowNumber & " | " & _operatorNumber
			_arrowNumber
			```
