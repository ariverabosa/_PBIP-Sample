	measure 'Line Chart Title' = ```
			
			VAR _maxDate = MAX(DimDate[Date])
			VAR _year = YEAR(_maxDate)-1
			VAR _month = MONTH(_maxDate)
			VAR _CY_StartYear = IF(_month <= 6, _year - 1, _year)
			VAR _CY_EndYear = _CY_StartYear + 1
			VAR _CYNName = FORMAT(_CY_StartYear, "0000")  & "-" & FORMAT(MOD(_CY_EndYear, 100), "00")
			
			VAR _Session = SELECTEDVALUE(DimTerm[Session], "")
			VAR _YearName = SELECTEDVALUE(DimTerm[Academic Year Name], "")
			VAR _HasSession = _Session <> ""
			VAR _HasYear = TRIM(_YearName) <> ""
			
			RETURN
			"Distinct Students by Academic Year" & 
			SWITCH(
			        TRUE(),
			        _HasSession && _HasYear,        ", " & _Session,
			        _HasSession && NOT _HasYear,    ", " & _Session,
			        NOT _HasSession && _HasYear,    _YearName
			                                
			    )
			```
		displayFolder: Line Chart
		lineageTag: af7e0c08-b5b6-4125-9a8b-7b4872a8b5d7

	measure 'Line Chart shade' = [Line Chart Max Axis] - [Distinct Students DaysBetween]
		displayFolder: Line Chart
		lineageTag: d8165bb0-704a-48e8-9d8f-55a177b2e5d2

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Line Chart Max Axis' =
			
			1.3 *
			MAXX(
			    ALLSELECTED(DimTerm[Academic Year Name]),
			    CALCULATE([Distinct Students DaysBetween])
			)
		displayFolder: Line Chart
		lineageTag: dd1b9fd9-3f24-4a29-ae60-a5597971040b

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Bullet Chart Title' = ```
			
			VAR _maxDate = MAX(DimDate[Date])
			VAR _year = YEAR(_maxDate)-1
			VAR _month = MONTH(_maxDate)
			VAR _CY_StartYear = IF(_month <= 6, _year - 1, _year)
			VAR _CY_EndYear = _CY_StartYear + 1
			VAR _CYNName = FORMAT(_CY_StartYear, "0000")  & "-" & FORMAT(MOD(_CY_EndYear, 100), "00")
			
			VAR _Session = SELECTEDVALUE(DimTerm[Session], "")
			VAR _YearName = SELECTEDVALUE(DimTerm[Academic Year Name], "")
			VAR _HasSession = _Session <> ""
			VAR _HasYear = TRIM(_YearName) <> ""
			
			RETURN
			"Students with Activity by Academic School, " & 
			
			SWITCH(
			        TRUE(),
			        _HasSession && _HasYear,       _YearName & " "&  _Session,
			        _HasSession && NOT _HasYear,     _Session,
			        NOT _HasSession && _HasYear,     _YearName
			                                
			    )
			```
		displayFolder: Activity by scholl chart
		lineageTag: 64ba6ab6-71b4-478a-8647-7d9a3298a16e

	measure 'Top  N Chart Title' = ```
			
			VAR _maxDate = MAX(DimDate[Date])
			VAR _year = YEAR(_maxDate)-1
			VAR _month = MONTH(_maxDate)
			VAR _CY_StartYear = IF(_month <= 6, _year - 1, _year)
			VAR _CY_EndYear = _CY_StartYear + 1
			VAR _CYNName = FORMAT(_CY_StartYear, "0000")  & "-" & FORMAT(MOD(_CY_EndYear, 100), "00")
			
			VAR _Session = SELECTEDVALUE(DimTerm[Session], "")
			VAR _YearName = SELECTEDVALUE(DimTerm[Academic Year Name], "")
			VAR _HasSession = _Session <> ""
			VAR _HasYear = TRIM(_YearName) <> ""
			
			RETURN
			"Top 5 Programs by Students with Activity, " & 
			SWITCH(
			        TRUE(),
			        _HasSession && _HasYear,       _YearName & " "&  _Session,
			        _HasSession && NOT _HasYear,     _Session,
			        NOT _HasSession && _HasYear,     _YearName
			                                
			    )
			```
		displayFolder: Top N Chart
