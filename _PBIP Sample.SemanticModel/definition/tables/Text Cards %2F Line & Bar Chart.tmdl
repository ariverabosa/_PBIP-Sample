	measure 'Card 1-4 Reference label color value' = ```
			
			VAR _value = [Distinct Students DaysBetween] - [Distinct Students DaysBetween, LY]  // Keep this as is
			VAR _pct = DIVIDE ( _value, [Distinct Students DaysBetween, LY] ) // Keep this as is
			VAR _valueLY = [Distinct Students DaysBetween, LY]
			
			VAR _absPct = ABS(_pct)
			VAR _absValue = ABS(_value)
			
			VAR _format = 
			    SWITCH(
			        TRUE(),
			        _pct > 0, "Green",
			        _pct < 0, "Red",
			        "Grey"
			    )
			RETURN
			_format 
			```
		displayFolder: Annual
		lineageTag: 26db2998-1970-41b4-bff1-228acd848fe3

	measure 'Card 2-5 Reference label color value' = ```
			
			VAR _value = [Distinct Students, Domestic (Non-Indigenous)] - [Distinct Students, Domestic (Non-Indigenous), LY]  // Keep this as is
			VAR _pct = DIVIDE ( _value, [Distinct Students, Domestic (Non-Indigenous), LY] ) // Keep this as is
			VAR _valueLY = [Distinct Students, Domestic (Non-Indigenous), LY]
			
			VAR _absPct = ABS(_pct)
			VAR _absValue = ABS(_value)
			
			VAR _pctRounded =
			    ROUND ( _pct, 2 )
			
			VAR _format =
			    SWITCH (
			        TRUE (),
			        ISBLANK ( _pct ), "Grey",
			        _pctRounded <= -0.01, "Red",
			        _pctRounded >= 0.01, "Green",
			        "Grey"
			    )
			
			RETURN
			_format 
			```
		displayFolder: Domestic (Non-Indigenous)
		lineageTag: 4d13f974-6571-40a6-9faa-d55a721218de

