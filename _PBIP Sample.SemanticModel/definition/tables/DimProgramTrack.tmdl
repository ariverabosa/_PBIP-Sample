	partition DimProgramTrack = m
		mode: import
		queryGroup: Dimensions
		source = ```
				let
				    Source = Sql.Database(Server, DataBase), 
				    Query=
				    "
				    SELECT 
				        /*
				    CASE 
				        WHEN pt.ReportGroup IS NULL 
				        THEN 'Other' 
				        ELSE pt.ReportGroup 
				     END AS New_ReportGroup,
				    */ 
				        pt.* 
				    FROM DimProgramTrack pt
				    WHERE CurrentFlag <> 0;
				    ",
				    Result = Value.NativeQuery(Source, Query),
				    #"Check No Rows" = Table.RowCount( Result),
				    #"SQL Result" = Result
				in
				    #"SQL Result"
				```

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

